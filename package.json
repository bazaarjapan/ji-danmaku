{
  "name": "ji-danmaku",
  "version": "0.1.1",
  "description": "ニコニコ動画風の弾幕をデスクトップ全面にオーバーレイ表示するアプリ。画面とマイクを監視し、Codex/Claude をブレインにして視聴者コメント(弾幕)をリアルタイム生成する。",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test",
    "dist": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.bazaarjapan.ji-danmaku",
    "productName": "Ji-Danmaku",
    "asar": false,
    "files": [
      "**/*",
      "!.env",
      "!.env.*",
      "!dist/**",
      "!test/**",
      "!.github/**",
      "!*.log",
      "!electron-*.log",
      "!build/icon.svg",
      "!build/icon.png",
      "!**/node_modules/onnxruntime-node/**",
      "!**/node_modules/sharp/**",
      "!**/node_modules/@img/**",
      "!renderer/_*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "ws": "^8.21.0"
  }
}
