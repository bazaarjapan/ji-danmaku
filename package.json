{
  "name": "ji-reaction-overlay",
  "version": "1.0.5",
  "description": "画面とマイクに反応する短いAIリアクションを、透明なデスクトップ補助オーバーレイに表示するElectronアプリ。",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test",
    "dist": "electron-builder --win",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "node scripts/build-mac.js",
    "dist:all": "npm run dist:win && npm run dist:mac",
    "dist:mac:release": "node scripts/verify-release-env.js mac && electron-builder --mac -c electron-builder.release.cjs",
    "dist:release": "node scripts/verify-release-env.js mac && electron-builder --win --mac -c electron-builder.release.cjs"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.bazaarjapan.ji-reaction",
    "productName": "Ji-Reaction",
    "asar": false,
    "afterExtract": "scripts/after-extract.js",
    "afterPack": "scripts/after-pack.js",
    "afterSign": "scripts/after-sign.js",
    "files": [
      "**/*",
      "!.env",
      "!.env.*",
      "!dist/**",
      "!test/**",
      "!.github/**",
      "!*.log",
      "!electron-*.log",
      "!build/icon.svg",
      "!build/icon.png",
      "!**/node_modules/onnxruntime-node/**",
      "!**/node_modules/sharp/**",
      "!**/node_modules/@img/**",
      "!renderer/_*"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "tray-icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "tray-icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "identity": "-",
      "icon": "build/icon-mac.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.entertainment",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Ji-Reaction uses microphone input to generate voice-reactive overlay reactions.",
        "NSScreenCaptureDescription": "Ji-Reaction captures the screen to generate context-aware overlay reactions."
      }
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "guid": "8966e3f8-5e96-523e-b4b4-d6c86404e297",
      "oneClick": false,
      "allowToChangeInstallationDirectory": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
